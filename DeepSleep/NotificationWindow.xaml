<Window x:Class="DeepSleep.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeepSleep"
        mc:Ignorable="d"
      Title="Deep Sleep Notification" ShowInTaskbar="False" WindowStartupLocation="Manual" Background="Transparent" WindowStyle="None" ResizeMode="NoResize" Icon="Appicon.ico" Height="150" Width="350" AllowsTransparency="True" Topmost="True" MouseRightButtonUp="Window_MouseRightButtonUp">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="(Window.Opacity)"
                                 From="0.0" To="1.0" Duration="0:0:1"
                                 AutoReverse="False"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Border Background="#F21C1A1A" CornerRadius="30">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24*"/>
                <ColumnDefinition Width="303*"/>
                <ColumnDefinition Width="24*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="17*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="10*"/>
            </Grid.RowDefinitions>
            <Image Grid.RowSpan="2" Source="/Resources/AppIcon.ico"  Width="35" Height="35" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="NotificationText" Text="До выключения осталось менее 30 мин" TextWrapping="Wrap" MaxWidth="270" Foreground="White" FontSize="19" VerticalAlignment="Bottom" Grid.ColumnSpan="2"/>
            </StackPanel>

            <TextBlock x:Name="CloseWindowText" Grid.Row="3" Grid.Column="1" Text="Окно закроется через 10 сек" Foreground="Gray" FontSize="12" VerticalAlignment="Top" Grid.ColumnSpan="2"/>
            <StackPanel x:Name="TimeAdditionPanel" Visibility="Collapsed" Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                <Button  Uid="5_min" Click="AddTimeButton_Click" Style="{DynamicResource AddTimeButtonStyle}" Height="32" Width="60" Content="+5 мин." Background="#FFB4B4B4" />
                <Button Uid="15_min" Click="AddTimeButton_Click" Style="{DynamicResource AddTimeButtonStyle}" Content="+15 мин." Height="32" Width="60" Margin="15 0" Background="#FFB4B4B4"/>
                <Button Uid="30_min" Click="AddTimeButton_Click" Style="{DynamicResource AddTimeButtonStyle}" Content="+30 мин." Height="32" Width="60" Background="#FFD812"/>
            </StackPanel>
            <StackPanel x:Name="YesNoPanel" Visibility="Collapsed" Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                <Button Uid="True" Style="{DynamicResource AddTimeButtonStyle}" Height="32" Width="60" Content="Да" Background="#FFBF3C3C" Click="YesNoClick"/>
                <Button Uid="False" Style="{DynamicResource AddTimeButtonStyle}" Content="Нет" Height="32" Width="60" Margin="15 0" Background="#FFD812" Click="YesNoClick"/>
            </StackPanel>
            <StackPanel x:Name="OKPanel" Visibility="Collapsed" Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                <Button Click="OK_Click" Style="{DynamicResource AddTimeButtonStyle}" Content="ОК" Height="32" Width="80" Background="#FFD812"/>
            </StackPanel>
        </Grid>

    </Border>
</Window>
